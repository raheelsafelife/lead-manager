{
  "name": "lead-manager-react-rebuild",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run api\" \"npm run client\"",
    "client": "vite --host 0.0.0.0 --port 5173",
    "api": "node server/index.js",
    "build": "vite build",
    "test": "node --test server/*.test.js",
    "test:external-lead": "node scripts/test-external-lead.mjs",
    "test:search-suggestions": "node scripts/test-search-suggestions.mjs",
    "migrate:aws": "node migrations/aws/migrate-sqlite-to-postgres.mjs",
    "migrate:aws:check": "node migrations/aws/migrate-sqlite-to-postgres.mjs",
    "preview": "vite preview --host 0.0.0.0 --port 4173"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.12.2",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "docx": "^9.5.1",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.468.0",
    "multer": "^2.0.2",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "recharts": "^2.15.0",
    "sql.js": "^1.12.0",
    "vite": "^6.0.7"
  }
}
